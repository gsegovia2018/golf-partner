{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview-arm64": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "GOLF_ANDROID_BUILD_ARCHS": "arm64-v8a"
      }
    },
    "preview-amd64": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "GOLF_ANDROID_BUILD_ARCHS": "x86_64"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
