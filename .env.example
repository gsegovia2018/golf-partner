# Supabase project — safe to expose (anon key is public by design).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Management API token (sbp_...). CI/CD ONLY — never ship in the app.
# Keep this in your CI secrets manager, NOT in a committed file.
# ACCESS_TOKEN_SUPABASE=
